# OpenRouter API key (server-side only — never shipped to the browser).
# Without it, /api/digest returns a deterministic fallback digest.
OPENROUTER_API_KEY=

# Model routed via OpenRouter. Swap to a cheaper model freely, e.g.
# anthropic/claude-haiku-4-5 or openai/gpt-4o-mini.
OPENROUTER_MODEL=anthropic/claude-opus-4-8

# Postgres connection string (server-side only). Without it, cards are not
# persisted: POST /api/digest still returns the card, GET /api/cards returns [].
# Example: postgresql://user:password@host:5432/dbname
DATABASE_URL=
